{
  "name": "Souzangar",
  "version": "0.3.1",
  "private": true,
  "description": "A template for cloning websites using AI, built with Next.js, Tailwind CSS, and Shadcn UI.",
  "author": "Vahid Afshari",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "website-clone",
    "reverse-engineering",
    "nextjs",
    "ai",
    "template",
    "tailwindcss",
    "shadcn-ui"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "sanity:seed": "node scripts/seed-sanity.mjs",
    "check": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@portabletext/react": "^6.2.0",
    "@sanity/image-url": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "next-sanity": "^13.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanity": "^6.2.0",
    "shadcn": "^4.1.0",
    "styled-components": "^6.4.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
